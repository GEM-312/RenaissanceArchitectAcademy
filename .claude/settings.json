{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(xcodebuild:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)"
    ],
    "deny": [
      "Read(/Users/pollakmarina/RenaissanceArchitectAcademy/RenaissanceArchitectAcademy/Services/APIKeys.swift)",
      "Edit(/Users/pollakmarina/RenaissanceArchitectAcademy/RenaissanceArchitectAcademy/Services/APIKeys.swift)",
      "Write(/Users/pollakmarina/RenaissanceArchitectAcademy/RenaissanceArchitectAcademy/Services/APIKeys.swift)",
      "Read(**/Services/APIKeys.swift)",
      "Edit(**/Services/APIKeys.swift)",
      "Write(**/Services/APIKeys.swift)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/bash-guard.py\""
          }
        ]
      }
    ]
  }
}
